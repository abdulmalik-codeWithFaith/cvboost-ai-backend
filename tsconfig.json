{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,

    "outDir": "./dist",

    "ignoreDeprecations": "6.0"
  }
}